# AGRIVO — variables d'environnement (copier en .env.local ; JAMAIS commité, .env* est ignoré)

# IA réelle (Gemini). Sans cette clé : MOCK_MODE automatique (démo 100 % hors réseau, sûre).
# Obtenir une clé : https://aistudio.google.com/apikey — à poser AUSSI sur Vercel (Settings → Environment Variables).
GEMINI_API_KEY=

# Modèle Gemini (optionnel, défaut : gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
