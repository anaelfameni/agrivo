# AGRIVO — variables d'environnement (copier en .env.local ; JAMAIS commité, .env* est ignoré)

# IA réelle (Gemini). Sans cette clé : MOCK_MODE automatique (démo 100 % hors réseau, sûre).
# Obtenir une clé : https://aistudio.google.com/apikey — à poser AUSSI sur Vercel (Settings → Environment Variables).
GEMINI_API_KEY=

# Modèle Gemini (optionnel, défaut : gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Détection satellite RÉELLE (API Whisp, FAO Open Foris). Sans cette clé : moteur d'évaluation
# déterministe calibré sur la méthode Whisp (repli garanti — la démo ne casse jamais).
# Obtenir une clé : compte gratuit sur https://whisp.openforis.org — à poser AUSSI sur Vercel.
WHISP_API_KEY=

# Base de l'API Whisp (optionnel, défaut : https://whisp.openforis.org/api)
# WHISP_API_URL=https://whisp.openforis.org/api
